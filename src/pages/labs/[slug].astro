---
// src/pages/labs/[slug].astro
import { getCollection, getEntry } from "astro:content";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

export async function getStaticPaths() {
  const labs = await getCollection("labs", ({ data }) => !data.draft);
  return labs.map((lab) => ({ params: { slug: lab.slug }, props: { lab } }));
}

const { lab } = Astro.props;
const { Content } = await lab.render();

const {
  title,
  description,
  category,
  status,
  techStack,
  demoUrl,
  githubUrl,
  startDate,
  updatedDate,
  metrics,
  relatedArticle,
} = lab.data;

// Labs relacionados (misma categoría, excluyendo el actual)
const allLabs = await getCollection(
  "labs",
  ({ data, slug }) => !data.draft && slug !== lab.slug,
);
const related = allLabs.filter((l) => l.data.category === category).slice(0, 3);

const statusConfig = {
  live: { label: "Live · Actualizado recientemente", color: "var(--mint)" },
  wip: { label: "En progreso", color: "var(--peach-dark)" },
  idea: { label: "Próximamente", color: "var(--blue-dark)" },
  archived: { label: "Archivado", color: "#9ca3af" },
};
const catLabel = {
  ia: "IA aplicada a producto",
  fintech: "Fintech",
  pm: "Product Management",
};
const tagClass = { ia: "tag-ia", fintech: "tag-fintech", pm: "tag-pm" };

const startStr = startDate.toLocaleDateString("es-MX", {
  month: "long",
  year: "numeric",
});
const updatedStr = updatedDate?.toLocaleDateString("es-MX", {
  month: "long",
  year: "numeric",
});
---

<Base titulo={`${title} — Labs · FerTechPro`} descripcion={description}>
  <Nav />
  <div class="progress-bar" id="progress"></div>

  <!-- BREADCRUMB -->
  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb" aria-label="Navegación">
        <a href="/">Inicio</a>
        <span class="sep">›</span>
        <a href="/labs">Labs</a>
        <span class="sep">›</span>
        <span>{title}</span>
      </nav>
    </div>
  </div>

  <!-- HERO -->
  <header class="project-hero">
    <div class="hero-deco-1"></div>
    <div class="hero-deco-2"></div>

    <div class="container">
      <div class="hero-inner">
        <div>
          <!-- Status + categoría -->
          <div class="status-row">
            {
              status === "live" && (
                <span class="status-pill live">
                  <span class="live-dot" />
                  {statusConfig.live.label}
                </span>
              )
            }
            {
              status === "wip" && (
                <span class="status-pill wip">{statusConfig.wip.label}</span>
              )
            }
            {
              status === "archived" && (
                <span class="status-pill archived">
                  📦 {statusConfig.archived.label}
                </span>
              )
            }
            <span class={`tag ${tagClass[category]}`}>{catLabel[category]}</span
            >
          </div>

          <h1 class="project-title">{title}</h1>
          <p class="project-subtitle">{description}</p>

          <!-- CTAs -->
          <div class="project-actions">
            {
              demoUrl && (
                <a
                  href={demoUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn-demo"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <>
                      <circle cx="12" cy="12" r="10" />
                      <polygon points="10 8 16 12 10 16 10 8" />
                    </>
                  </svg>
                  Ver demo en vivo
                </a>
              )
            }
            {
              githubUrl && (
                <a
                  href={githubUrl}
                  target="_blank"
                  rel="noopener"
                  class="btn-code"
                >
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <>
                      <polyline points="16 18 22 12 16 6" />
                      <polyline points="8 6 2 12 8 18" />
                    </>
                  </svg>
                  Ver en GitHub
                </a>
              )
            }
          </div>

          <!-- Meta -->
          <div class="project-meta-row">
            <div class="meta-item">
              <span class="meta-label">Inicio</span>
              <span class="meta-value">{startStr}</span>
            </div>
            {
              updatedStr && (
                <div class="meta-item">
                  <span class="meta-label">Actualizado</span>
                  <span class="meta-value">{updatedStr}</span>
                </div>
              )
            }
            <div class="meta-item">
              <span class="meta-label">Estado</span>
              <span
                class="meta-value"
                style={`color:${statusConfig[status].color}`}
              >
                {
                  status === "live"
                    ? "🟢 Live"
                    : status === "wip"
                      ? "🟠 En progreso"
                      : status === "archived"
                        ? "📦 Archivado"
                        : "🔵 Próximamente"
                }
              </span>
            </div>
            {
              metrics?.[0] && (
                <div class="meta-item">
                  <span class="meta-label">
                    {metrics[0].label.split(" ").slice(0, 2).join(" ")}
                  </span>
                  <span class="meta-value">{metrics[0].value}</span>
                </div>
              )
            }
          </div>
        </div>

        <!-- Right column placeholder (desktop) -->
        <div></div>
      </div>
    </div>
  </header>

  <!-- CONTENT COLUMN -->
  <div class="project-outer">
    <div class="project-col">
      <!-- TECH STACK -->
      <div class="tech-section">
        <div class="tech-label">Stack técnico</div>
        <div class="tech-pills">
          {
            techStack.map((t, i) => (
              <span class={`tech-pill${i < 3 ? " main" : ""}`}>{t}</span>
            ))
          }
        </div>
      </div>

      <!-- METRICS GRID -->
      {
        metrics && metrics.length > 0 && (
          <div class="metrics-grid">
            {metrics.map((m) => (
              <div class="metric-box">
                <div class="metric-num">{m.value}</div>
                <div class="metric-label">{m.label}</div>
              </div>
            ))}
          </div>
        )
      }

      <!-- MARKDOWN CONTENT -->
      <div class="project-body">
        <Content />
      </div>

      <!-- ARTÍCULO RELACIONADO -->
      {
        relatedArticle && (
          <a href={`/articulos/${relatedArticle}`} class="article-link-card">
            <div>
              <div class="article-link-label">📝 Artículo relacionado</div>
              <div class="article-link-title">
                Lee el artículo donde explico cómo construí este proyecto →
              </div>
            </div>
            <span class="article-link-arrow">→</span>
          </a>
        )
      }

      <!-- LABS RELACIONADOS -->
      {
        related.length > 0 && (
          <div class="related-labs">
            <p class="related-label">Otros labs que podrían interesarte</p>
            <div class="related-grid">
              {related.map((l) => (
                <a href={`/labs/${l.slug}`} class="related-card">
                  <span
                    class={`tag ${tagClass[l.data.category]}`}
                    style="font-size:.6rem;"
                  >
                    {catLabel[l.data.category]}
                  </span>
                  <div class="related-name">{l.data.title}</div>
                  <p class="related-desc">{l.data.description}</p>
                  <span class="related-link">Ver proyecto →</span>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>

  <Footer />
</Base>

<script>
  // Barra de progreso de lectura
  window.addEventListener("scroll", () => {
    const el = document.getElementById("progress");
    if (!el) return;
    const max =
      document.documentElement.scrollHeight -
      document.documentElement.clientHeight;
    el.style.width = (document.documentElement.scrollTop / max) * 100 + "%";
  });
</script>

<style>
  /* ── PROGRESS BAR ──────────────────────────────── */
  .progress-bar {
    position: fixed;
    top: 56px;
    left: 0;
    height: 2px;
    background: var(--blue-dark);
    z-index: 99;
    transition: width 0.1s linear;
    width: 0%;
  }

  /* ── BREADCRUMB ────────────────────────────────── */
  .breadcrumb-bar {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--white);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--gray);
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--blue-dark);
    text-decoration: none;
  }
  .sep {
    color: var(--border);
  }

  /* ── HERO ──────────────────────────────────────── */
  .project-hero {
    background: linear-gradient(135deg, #1a1a2e 55%, #2d3561);
    color: var(--white);
    overflow: hidden;
    position: relative;
    padding: 2.5rem 0 2rem;
  }
  .hero-deco-1 {
    position: absolute;
    width: 350px;
    height: 350px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--blue-mid), transparent 65%);
    opacity: 0.12;
    top: -100px;
    right: -60px;
  }
  .hero-deco-2 {
    position: absolute;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--mint), transparent 65%);
    opacity: 0.08;
    bottom: -50px;
    left: 5%;
  }
  .hero-inner {
    position: relative;
    z-index: 1;
  }

  .status-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .status-pill.live {
    color: var(--mint);
  }
  .status-pill.wip {
    color: var(--peach);
  }
  .live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--mint);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  .project-title {
    font-family: "Fraunces", serif;
    font-size: clamp(1.75rem, 5vw, 2.8rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .project-subtitle {
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.75rem;
    max-width: 560px;
  }

  .project-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }
  .btn-demo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    padding: 0.7rem 1.5rem;
    background: var(--blue-dark);
    color: var(--white);
    border: 1px solid var(--blue-dark);
    text-decoration: none;
    transition: background 0.15s;
  }
  .btn-demo:hover {
    background: #3a7db0;
  }
  .btn-code {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    padding: 0.7rem 1.5rem;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.2);
    text-decoration: none;
  }
  .btn-code:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: var(--white);
  }

  .project-meta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .meta-item {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .meta-label {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
  }
  .meta-value {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.8);
  }

  /* ── CONTENT ───────────────────────────────────── */
  .project-outer {
    padding: 2rem 0 4rem;
  }
  .project-col {
    width: 100%;
    max-width: 700px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  /* Tech stack */
  .tech-section {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 1.25rem;
    margin-bottom: 2rem;
  }
  .tech-label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 0.75rem;
  }
  .tech-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tech-pill {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--gray);
    background: var(--bg);
  }
  .tech-pill.main {
    background: var(--blue-light);
    border-color: var(--blue-mid);
    color: #1e4a8a;
  }

  /* Metrics */
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 2rem;
  }
  .metric-box {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 1.25rem;
  }
  .metric-num {
    font-family: "Fraunces", serif;
    font-size: 1.8rem;
    font-weight: 600;
    color: var(--blue-dark);
    line-height: 1;
    margin-bottom: 0.3rem;
  }
  .metric-label {
    font-size: 0.72rem;
    color: var(--gray);
    line-height: 1.4;
  }

  /* Markdown body */
  .project-body {
    font-size: 1rem;
    line-height: 1.85;
    color: #2d2d3a;
    margin-bottom: 2.5rem;
  }
  .project-body :global(p) {
    margin-bottom: 1.5rem;
  }
  .project-body :global(h2) {
    font-family: "Fraunces", serif;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
    color: var(--black);
  }
  .project-body :global(h3) {
    font-family: "Fraunces", serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
  }
  .project-body :global(ul),
  .project-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
  }
  .project-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .project-body :global(strong) {
    font-weight: 500;
    color: var(--black);
  }
  .project-body :global(blockquote) {
    border-left: 3px solid var(--blue-dark);
    padding: 0.75rem 1.25rem;
    margin: 2rem 0;
    background: var(--white);
    font-style: italic;
    color: var(--gray);
    line-height: 1.7;
  }
  .project-body :global(a) {
    color: var(--blue-dark);
    border-bottom: 1px solid var(--blue-light);
    text-decoration: none;
  }
  .project-body :global(pre) {
    background: #1a1a2e;
    border-radius: 4px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }
  .project-body :global(code) {
    font-family: "Fira Code", "Courier New", monospace;
    font-size: 0.82rem;
    line-height: 1.7;
    color: #adf7b6;
  }
  .project-body :global(p code) {
    background: var(--blue-light);
    color: #1e4a8a;
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-size: 0.88em;
  }
  .project-body :global(hr) {
    border: none;
    border-top: 1px solid var(--border);
    margin: 2.5rem 0;
  }

  /* Artículo relacionado */
  .article-link-card {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 2rem 0;
    transition: border-color 0.2s;
    text-decoration: none;
    color: var(--black);
  }
  .article-link-card:hover {
    border-color: var(--blue-mid);
  }
  .article-link-label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 0.4rem;
  }
  .article-link-title {
    font-family: "Fraunces", serif;
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.3;
  }
  .article-link-arrow {
    font-size: 1.25rem;
    color: var(--blue-dark);
    flex-shrink: 0;
  }

  /* Labs relacionados */
  .related-labs {
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    margin-top: 3rem;
  }
  .related-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1.25rem;
  }
  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .related-card {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition:
      border-color 0.2s,
      transform 0.2s;
    text-decoration: none;
    color: var(--black);
  }
  .related-card:hover {
    border-color: var(--blue-mid);
    transform: translateY(-2px);
  }
  .related-name {
    font-family: "Fraunces", serif;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .related-desc {
    font-size: 0.8rem;
    color: var(--gray);
    line-height: 1.6;
  }
  .related-link {
    font-size: 0.75rem;
    color: var(--blue-dark);
    border-bottom: 1px solid var(--blue-light);
    padding-bottom: 1px;
    align-self: flex-start;
  }

  .status-pill.archived {
    color: #9ca3af;
  }

  /* ── RESPONSIVE ────────────────────────────────── */
  @media (min-width: 640px) {
    .project-col {
      padding: 0 2rem;
    }
    .metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .related-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (min-width: 1024px) {
    .progress-bar {
      top: 64px;
    }
    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 4rem;
    }
    .project-col {
      padding: 0;
    }
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
