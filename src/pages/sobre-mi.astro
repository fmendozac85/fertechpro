---
// src/pages/sobre-mi.astro
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

// Últimos artículos (usa los campos reales del schema)
const articulos = await getCollection("articulos");
const ultimos = articulos
  .sort((a, b) => b.data.fecha.getTime() - a.data.fecha.getTime())
  .slice(0, 3);

const tagClass = { ia: "tag-ia", fintech: "tag-fintech", pm: "tag-pm" };

const experiencia = [
  {
    role: "Senior Technical Product Manager",
    company: "Inteseguro — Seguros · Perú",
    period: "2024 — 2025",
    desc: "Lideré 5 squads bajo modelo agile y logré +4 pts tasa conversión nueva web Soat y +15% leads por consentimiento por whatsapp linea Vida Tradicional.",
    tags: [
      "B2C eCommerce",
      "Pólizas seguro vida",
      "Canales digitales y tradicionales",
    ],
  },
  {
    role: "Business Cluster Tech & Product Lead",
    company: "La Positiva — Seguros · Perú",
    period: "2023 — 2024",
    desc: "Lideré 3 squads bajo modelo agile en cluster vehicular y logré +15% TTM por modernización eCommerce Soat.",
    tags: ["Pólizas SOAT", "B2B eCommerce", "Modernización plataforma"],
  },
  {
    role: "Product Manager Lead - Innovación",
    company: "Tottus — Retail · Perú",
    period: "2021 — 2023",
    desc: "Lideré productos digitales para las tiendas y backoffice logrando S/5M+ ahorro anual por recuperación rebates y mejora en +10% nivel servicio en góndola en tiendas.",
    tags: [
      "Reposición por venta",
      "Rebates",
      "Automatización procesos con RPA",
      "ML en ofertas",
    ],
  },
  {
    role: "Digital Technology Manager",
    company: "Belcorp",
    period: "2012 — 2021",
    desc: "Digitalización de la fuerza de ventas directa y personalización de ofertas, logrando $+70M venta incremental y +200% productividad con marcos ágiles (Scrum-Kanban-SAFe).",
    tags: ["Venta Directa", "eCommerce B2B", "ML en ofertas"],
  },
];

const skills = [
  {
    label: "Product core",
    items: [
      "Priorización",
      "Story mapping",
      "Customer Journey",
      "Roadmapping",
      "OKRs",
      "PRDs",
      "Stakeholder mgmt",
      "Business Case",
      "Estrategias Go-To market",
    ],
    highlight: [0, 1],
  },
  {
    label: "Datos & análisis",
    items: [
      "SQL",
      "Google Analytics",
      "Firebase",
      "Hotjar/Fullstory",
      "Tableau",
      "A/B testing",
    ],
    highlight: [0, 1],
  },
  {
    label: "IA aplicada",
    items: [
      "Prompt engineering",
      "Claude / GPT-4",
      "Visual Studio Code",
      "LLM workflows",
      "NoCode",
    ],
    highlight: [0, 1],
  },
  {
    label: "Tools & stack",
    items: [
      "Jira/Confluence",
      "Notion",
      "Figma",
      "Mural/Miro",
      "MS Office",
      "Canva",
    ],
    highlight: [3],
  },
];
---

<Base
  titulo="Sobre mí — FerTechPro"
  descripcion="PM con 8+ años en fintech latinoamericana. Construyo productos financieros que sirven a personas reales — y experimento con IA para que ese proceso sea más inteligente."
>
  <Nav />

  <!-- BREADCRUMB -->
  <div class="breadcrumb-bar">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">Inicio</a>
        <span>›</span>
        <span>Sobre mí</span>
      </nav>
    </div>
  </div>

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="about-hero">
    <div class="container">
      <div class="about-hero-inner">
        <!-- Avatar -->
        <div class="avatar-wrap">
          <div class="avatar">
            <img
              src="/imagenes/miFoto/miFoto.png"
              alt="Fernando Mendoza Canta"
            />
            <!-- <svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg"
                 style="width:100%;height:100%;background:#e8f4fc;">
              <ellipse cx="80" cy="58" rx="36" ry="40" fill="#4a90c4" opacity=".9"/>
              <circle cx="80" cy="50" r="24" fill="#ffd4a8"/>
              <ellipse cx="80" cy="55" rx="13" ry="6" fill="#e8b88a"/>
              <rect x="60" y="44" width="14" height="9" rx="4" fill="none" stroke="#1a1a2e" stroke-width="2"/>
              <rect x="78" y="44" width="14" height="9" rx="4" fill="none" stroke="#1a1a2e" stroke-width="2"/>
              <line x1="74" y1="48" x2="78" y2="48" stroke="#1a1a2e" stroke-width="2"/>
              <path d="M40 160 Q40 110 80 105 Q120 110 120 160" fill="#2d3a8c" opacity=".85"/>
              <path d="M70 105 L80 118 L90 105" fill="white" opacity=".9"/>
              <rect x="55" y="128" width="50" height="22" rx="3" fill="#1a1a2e" opacity=".6"/>
              <rect x="57" y="130" width="46" height="17" rx="2" fill="#4a90c4" opacity=".35"/>
            </svg>-->
          </div>
          <div class="avatar-badge">✓ Open to work</div>
        </div>

        <!-- Texto -->
        <div class="about-text">
          <p class="eyebrow">Senior Product Manager</p>
          <h1 class="about-name">Fernando<br /><em>Mendoza Canta</em></h1>
          <p class="about-tagline">
            PM con 9+ años liderando productos digitales en sectores como
            seguros, retail y venta directa y 17 años de experiencia. Combino
            liderazgo de equipos, product management con alto enfoque en
            discovery y profundidad técnica para brindar la mejor experiencia de
            usuario y cumplir los objetivos de negocio. <br /><strong
              >Soy un apasionado por el mundo FinTech.</strong
            >
          </p>
          <div class="about-ctas">
            <a
              href="https://www.linkedin.com/in/fernando-mendoza-canta/"
              target="_blank"
              rel="noopener"
              class="btn-primary"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path
                  d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                ></path>
              </svg>
              Conectar en LinkedIn
            </a>
            <!--
            <a href="/cv-fernando-mendoza.pdf" class="btn-secondary"
              >Descargar CV →</a
            > -->
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── STATS ─────────────────────────────────────────────────────── -->
  <div class="stats-strip">
    <div class="container">
      <div class="stats-grid">
        {
          [
            { num: "9+", desc: "Años en Product Management" },
            { num: "$70M+", desc: "Venta incremental lograda" },
            { num: "800K+", desc: "Usuarios impactados con mis productos" },
            { num: "4", desc: "Labs y proyectos propios publicados" },
          ].map((s) => (
            <div class="stat-box">
              <div class="stat-num">{s.num}</div>
              <div class="stat-desc">{s.desc}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- ── BIO ───────────────────────────────────────────────────────── -->
  <section class="bio-section">
    <div class="container">
      <div class="bio-inner">
        <div class="bio-main">
          <h2>Mi historia</h2>
          <div class="bio-text">
            <p>
              Empecé mi carrera como developer en una empresa de
              telecomunicaciones donde pude <strong
                >interactuar tanto con perfiles comerciales como técnicos</strong
              >. Si bien aquí mi rol fue el <strong
                >desarrollo full stack</strong
              > implementando el front-end/backend de websites y móviles, esta interacciones
              con roles comerciales me preparo para lo que se venía.
            </p>

            <p>
              Años despues, me desarrollé en gestión de proyectos llevando
              proyectos de transformación digital y fue en el 2016 donde empecé
              a especializarme en product management llevando productos
              digitales de alta transaccionalidad y escala.
            </p>
            <!--
            <blockquote>
              "Lo que más me importa no es la feature — es el problema que
              resuelve. Y en fintech, ese problema suele tener consecuencias
              reales en la vida de personas reales."
            </blockquote>
 -->
            <p>
              En 2025 noté seriamente cómo la IA puede cambiar la forma en que
              los PMs construimos productos digitales. No como hype, sino como
              tooling concreto. Ese experimento lo enfoqué en pymes y se llamó
              FerTechPro-Automations.
            </p>

            <p>
              Siempre me han atraido las finanzas y desde el 2025 voy explorando
              el mundo Fintech y las oportunidades que hay en LATAM para ofrecer
              soluciones que reduzcan la inclusión financiera y traigan
              desarrollo al ciudadano de a pie.
            </p>

            <p>
              Fuera del trabajo, soy aficionado de las inversiones, al baile
              (salsa) y los deportes.
            </p>
          </div>
        </div>

        <!-- Sidebar: dónde escribo -->
        <div class="bio-side">
          <h3>Dónde escribo</h3>
          <div class="writing-list">
            {
              [
                {
                  title: "FerTechPro Blog",
                  desc: "Artículos sobre Producto, Fintech e IA aplicada",
                },
                {
                  title: "Newsletter semanal",
                  desc: "Comparto opiniones, oportunidades y casos prácticos (Labs)",
                },
                {
                  title: "LinkedIn",
                  desc: "Posts sobre PM + Fintech + IA en contexto latam",
                },
              ].map((w) => (
                <div class="writing-item">
                  <div class="writing-title">{w.title}</div>
                  <div class="writing-desc">{w.desc}</div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── EXPERIENCIA ───────────────────────────────────────────────── -->
  <section class="exp-section">
    <div class="container">
      <h2>Experiencia</h2>
      <div class="timeline">
        {
          experiencia.map((e) => (
            <div class="timeline-item">
              <div class="timeline-header">
                <div>
                  <div class="timeline-role">{e.role}</div>
                  <div class="timeline-company">{e.company}</div>
                </div>
                <div class="timeline-period">{e.period}</div>
              </div>
              <p class="timeline-desc">{e.desc}</p>
              <div class="timeline-tags">
                {e.tags.map((t) => (
                  <span class="t-tag">{t}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── SKILLS ────────────────────────────────────────────────────── -->
  <section class="skills-section">
    <div class="container">
      <h2>Herramientas & skills</h2>
      <div class="skills-grid">
        {
          skills.map((group) => (
            <div class="skill-group">
              <div class="skill-group-label">{group.label}</div>
              <div class="skill-pills">
                {group.items.map((item, i) => (
                  <span
                    class={`skill-pill${group.highlight.includes(i) ? " highlight" : ""}`}
                  >
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── PILARES ───────────────────────────────────────────────────── -->
  <section class="pillars-section">
    <div class="container">
      <h2>Sobre qué escribo y experimento</h2>
      <div class="pillars-list">
        {
          [
            {
              dot: "pm",
              title: "Product Management real",
              desc: "Sin frameworks de libros. Casos concretos y opiniones sobre toma de decisiones difíciles, priorización bajo incertidumbre y cómo trabajar con engineering cuando el tiempo aprieta.",
            },
            {
              dot: "fintech",
              title: "Fintech latinoamericana",
              desc: "Crédito, pagos, cuentas y seguros en mercados donde el 60% de las personas nunca tuvo una cuenta bancaria. Oportunidades relevantes.",
            },
            {
              dot: "ia",
              title: "IA aplicada a producto",
              desc: "Cómo los PMs podemos usar IA como herramienta de trabajo, no como buzzword. Desde prompts útiles hasta automatizaciones que ahorran horas reales.",
            },
          ].map((p) => (
            <div class="pillar-card">
              <div class={`pillar-dot dot-${p.dot}`} />
              <div>
                <div class="pillar-title">{p.title}</div>
                <p class="pillar-desc">{p.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ── CTA CONTACTO ──────────────────────────────────────────────── -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-inner">
        <div>
          <h2>¿Trabajamos juntos<br /><em>en algo?</em></h2>
          <p>
            Estoy abierto a conversaciones sobre roles de PM senior, advisory en
            fintechs, o simplemente intercambiar ideas sobre producto e IA.
          </p>
        </div>
        <div class="cta-links">
          <a href="mailto:fmendozac85@gmail.com" class="cta-btn primary"
            >Escribirme →</a
          >
          <a
            href="https://www.linkedin.com/in/fernando-mendoza-canta/"
            target="_blank"
            rel="noopener"
            class="cta-btn ghost">LinkedIn</a
          >
        </div>
      </div>
    </div>
    <Footer />
  </section>

  <style>
    /* ── BREADCRUMB ─────────────────────────────────── */
    .breadcrumb-bar {
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--border);
      background: var(--white);
    }
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.75rem;
      color: var(--gray);
    }
    .breadcrumb a {
      color: var(--blue-dark);
      text-decoration: none;
    }

    /* ── HERO ──────────────────────────────────────── */
    .about-hero {
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
      background: var(--cream);
    }
    .about-hero-inner {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    .avatar-wrap {
      position: relative;
      width: 110px;
    }
    .avatar {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      overflow: hidden;
      border: 3px solid var(--white);
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    }
    .avatar img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .avatar-badge {
      position: absolute;
      bottom: 2px;
      right: -4px;
      background: var(--mint);
      border: 2px solid var(--white);
      border-radius: 20px;
      font-size: 0.6rem;
      font-weight: 500;
      padding: 0.15rem 0.5rem;
      color: var(--mint-dark);
    }

    .eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--blue-dark);
      margin-bottom: 0.5rem;
    }
    .about-name {
      font-family: "Fraunces", serif;
      font-size: clamp(2rem, 7vw, 3.2rem);
      font-weight: 600;
      line-height: 1.08;
      letter-spacing: -0.03em;
      margin-bottom: 0.75rem;
    }
    .about-name em {
      font-style: italic;
      font-weight: 300;
      color: var(--blue-dark);
    }
    .about-tagline {
      font-size: 0.95rem;
      line-height: 1.75;
      color: var(--gray);
      margin-bottom: 1.25rem;
      max-width: 560px;
    }
    .about-ctas {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 500;
      padding: 0.7rem 1.5rem;
      background: var(--blue-dark);
      color: var(--white);
      border: 1px solid var(--blue-dark);
      text-decoration: none;
      transition: background 0.15s;
    }
    .btn-primary:hover {
      background: #3a7db0;
    }
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      padding: 0.7rem 1.5rem;
      background: transparent;
      color: var(--black);
      border: 1px solid var(--border);
      text-decoration: none;
    }

    /* ── STATS ─────────────────────────────────────── */
    .stats-strip {
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }
    .stat-box {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 1rem 1.25rem;
    }
    .stat-num {
      font-family: "Fraunces", serif;
      font-size: 2rem;
      font-weight: 600;
      color: var(--blue-dark);
      line-height: 1;
      margin-bottom: 0.3rem;
    }
    .stat-desc {
      font-size: 0.72rem;
      color: var(--gray);
      line-height: 1.4;
    }

    /* ── BIO ────────────────────────────────────────── */
    .bio-section {
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .bio-inner {
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .bio-section h2,
    .bio-main h2 {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 1.25rem;
    }
    .bio-text {
      font-size: 0.92rem;
      line-height: 1.9;
      color: #2d2d3a;
    }
    .bio-text p {
      margin-bottom: 1.25rem;
    }
    .bio-text p:last-child {
      margin-bottom: 0;
    }
    .bio-text strong {
      font-weight: 500;
      color: var(--black);
    }
    .bio-text blockquote {
      border-left: 3px solid var(--blue-dark);
      padding: 0.75rem 1.25rem;
      margin: 1.5rem 0;
      background: var(--blue-light);
      font-style: italic;
      color: #1e3a5f;
      line-height: 1.7;
      font-size: 0.92rem;
    }

    .bio-side h3 {
      font-family: "Fraunces", serif;
      font-size: 1rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }
    .writing-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }
    .writing-item {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 1rem 1.25rem;
    }
    .writing-title {
      font-size: 0.82rem;
      font-weight: 500;
      margin-bottom: 0.25rem;
    }
    .writing-desc {
      font-size: 0.75rem;
      color: var(--gray);
    }

    /* ── EXPERIENCIA ────────────────────────────────── */
    .exp-section {
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .exp-section h2 {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 1.5rem;
    }
    .timeline {
      display: flex;
      flex-direction: column;
    }
    .timeline-item {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .timeline-item:last-child {
      border-bottom: none;
    }
    .timeline-header {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .timeline-role {
      font-size: 0.95rem;
      font-weight: 500;
    }
    .timeline-company {
      font-size: 0.82rem;
      color: var(--blue-dark);
    }
    .timeline-period {
      font-size: 0.72rem;
      color: var(--gray);
    }
    .timeline-desc {
      font-size: 0.85rem;
      line-height: 1.7;
      color: var(--gray);
    }
    .timeline-tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .t-tag {
      font-size: 0.65rem;
      padding: 0.15rem 0.55rem;
      border: 1px solid var(--border);
      color: var(--gray);
      border-radius: 20px;
    }

    /* ── SKILLS ─────────────────────────────────────── */
    .skills-section {
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .skills-section h2 {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin-bottom: 1.5rem;
    }
    .skills-grid {
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    .skill-group {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 1.25rem;
    }
    .skill-group-label {
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 0.75rem;
    }
    .skill-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
    }
    .skill-pill {
      font-size: 0.78rem;
      padding: 0.35rem 0.85rem;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--black);
      border-radius: 2px;
    }
    .skill-pill.highlight {
      background: var(--blue-light);
      border-color: var(--blue-mid);
      color: #1e4a8a;
    }

    /* ── PILARES ────────────────────────────────────── */
    .pillars-section {
      padding: 2.5rem 0;
      border-bottom: 1px solid var(--border);
      background: var(--cream);
    }
    .pillars-section h2 {
      font-family: "Fraunces", serif;
      font-size: 1.4rem;
