---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const articulos = await getCollection("articulos", ({ data }) => !data.draft);
  return articulos.map((a) => ({
    params: { slug: a.slug },
    props: { articulo: a },
  }));
}

const { articulo } = Astro.props;
const { titulo, pilar, extracto, lectura, fecha } = articulo.data;
const { Content } = await articulo.render();

const pilarLabel = {
  pm: "Product Management",
  fintech: "Fintech Latam",
  ia: "IA aplicada a producto",
};
const fechaFormato = new Date(fecha).toLocaleDateString("es-PE", {
  day: "numeric",
  month: "long",
  year: "numeric",
});
const urlArticulo = "https://fertechpro.com/articulos/" + articulo.slug;
const msgWA = encodeURIComponent(titulo + " — FerTechPro\n" + urlArticulo);
const msgLI = encodeURIComponent(urlArticulo);

const todos = await getCollection("articulos", ({ data }) => !data.draft);
const relacionados = todos
  .filter((a) => a.slug !== articulo.slug && a.data.pilar === pilar)
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf())
  .slice(0, 3);

const fotoB64 =
  "";
---

<Base titulo={titulo + " — FerTechPro"} descripcion={extracto} tipo="article">
  <Nav />
  <div class="progress-bar" id="progress"></div>

  <!-- BREADCRUMB -->
  <div class="breadcrumb-bar">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Inicio</a><span class="breadcrumb-sep">›</span>
        <a href="/articulos">Artículos</a><span class="breadcrumb-sep">›</span>
        <span
          class={"tag tag-" + pilar}
          style="font-size:.65rem;padding:.15rem .5rem;"
          >{pilarLabel[pilar]}</span
        >
      </div>
    </div>
  </div>

  <!-- HERO IMAGE -->
  <div class="article-hero">
    {
      articulo.data.imagen ? (
        <img
          src={articulo.data.imagen}
          alt={titulo}
          style="width:100%;height:100%;object-fit:cover;display:block;"
        />
      ) : (
        <div class={`article-hero-placeholder hero-${pilar}`}>
          <div class="hero-deco" />
          <span class="hero-label">Tu caricatura aquí</span>
        </div>
      )
    }
  </div>

  <!-- ARTICLE -->
  <div class="article-outer">
    <div class="article-col">
      <!-- HEADER -->
      <div class="article-header">
        <div class="article-header-meta">
          <span class={"tag tag-" + pilar}>{pilarLabel[pilar]}</span>
          <span style="font-size:.72rem;color:var(--gray);">{fechaFormato}</span
          >
        </div>
        <h1 class="article-title">{titulo}</h1>
        <p class="article-subtitle">{extracto}</p>

        <!-- AUTHOR BAR -->
        <div class="author-bar">
          <div class="author-info">
            <div class="author-avatar">
              <img
                src={"data:image/png;base64," + fotoB64}
                alt="Fernando Mendoza"
              />
            </div>
            <div>
              <div class="author-name">Fernando Mendoza</div>
              <div class="author-meta">Senior PM · Fintech · IA</div>
            </div>
          </div>
          <div class="article-actions">
            <span class="read-time">
              <svg
                width="13"
                height="13"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><circle cx="12" cy="12" r="10"></circle><polyline
                  points="12 6 12 12 16 14"></polyline></svg
              >
              {lectura} min lectura
            </span>
            <a
              href={"https://wa.me/?text=" + msgWA}
              target="_blank"
              class="share-btn share-wa"
            >
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                ><path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
                ></path><path
                  d="M12 0C5.373 0 0 5.373 0 12c0 2.099.544 4.07 1.497 5.785L0 24l6.385-1.475A11.947 11.947 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.012-1.372l-.36-.213-3.733.864.938-3.63-.234-.374A9.818 9.818 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"
                ></path></svg
              >
              Compartir
            </a>
          </div>
        </div>
      </div>

      <!-- BODY -->
      <div class="article-body">
        <Content />
      </div>

      <!-- TAGS -->
      <div class="article-tags">
        <span class="article-tags-label">Temas:</span>
        <span class={"tag tag-" + pilar}>{pilarLabel[pilar]}</span>
      </div>

      <!-- BOTTOM SHARE -->
      <div class="bottom-share">
        <span class="bottom-share-label">¿Te fue útil? Compártelo:</span>
        <div class="bottom-share-btns">
          <a
            href={"https://wa.me/?text=" + msgWA}
            target="_blank"
            class="share-btn share-wa"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path><path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.099.544 4.07 1.497 5.785L0 24l6.385-1.475A11.947 11.947 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.818 9.818 0 01-5.012-1.372l-.36-.213-3.733.864.938-3.63-.234-.374A9.818 9.818 0 012.182 12C2.182 6.58 6.58 2.182 12 2.182S21.818 6.58 21.818 12 17.42 21.818 12 21.818z"
              ></path></svg
            >
            WhatsApp
          </a>
          <a
            href={"https://www.linkedin.com/sharing/share-offsite/?url=" +
              msgLI}
            target="_blank"
            class="share-btn share-li"
          >
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
            LinkedIn
          </a>
        </div>
      </div>

      <!-- NEWSLETTER CTA -->
      <div class="newsletter-cta">
        <h3>Un artículo así, cada semana</h3>
        <p>Sin hype. Solo producto, fintech e IA con criterio real.</p>
        <form
          class="newsletter-cta-form"
          action="https://app.mailerlite.com/webforms/landing/TU_FORMULARIO"
          method="post"
          target="_blank"
        >
          <input
            type="email"
            name="email"
            placeholder="tu@email.com"
            required
          />
          <button type="submit">Suscribirme →</button>
        </form>
      </div>

      <!-- AUTHOR BIO -->
      <div class="author-bio">
        <div class="author-bio-avatar">
          <img
            src={"data:image/png;base64," + fotoB64}
            alt="Fernando Mendoza"
          />
        </div>
        <div>
          <div class="author-bio-name">Fernando Mendoza</div>
          <div class="author-bio-text">
            Senior PM con +9 años liderando productos digitales en seguros,
            retail y consumo masivo. Escribo sobre Product Management, Fintech e
            IA aplicada a producto — y aprendo experimentando con productos
            propios.
          </div>
          <a href="/articulos" class="author-bio-link"
            >Ver todos los artículos →</a
          >
        </div>
      </div>

      <!-- RELATED -->
      {
        relacionados.length > 0 && (
          <div class="related">
            <div class="related-label">Artículos relacionados</div>
            <div class="related-grid">
              {relacionados.map((a) => (
                <a href={"/articulos/" + a.slug} class="related-card">
                  <div class={"related-card-img"}>
                    <div
                      class={
                        "related-img-placeholder related-img-" + a.data.pilar
                      }
                    />
                  </div>
                  <div class="related-card-body">
                    <span
                      class={"tag tag-" + a.data.pilar}
                      style="font-size:.6rem;"
                    >
                      {pilarLabel[a.data.pilar]}
                    </span>
                    <div class="related-card-title">{a.data.titulo}</div>
                    <div class="related-card-meta">
                      {a.data.lectura} min lectura
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>

  <Footer />
</Base>

<style>
  .article-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    font-size: 0.9rem;
  }
  .article-body :global(th) {
    background: var(--black);
    color: var(--white);
    padding: 0.85rem 1.25rem;
    text-align: left;
    font-weight: 500;
    font-size: 0.8rem;
    letter-spacing: 0.05em;
  }
  .article-body :global(td) {
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--border);
    color: var(--gray);
    line-height: 1.6;
    vertical-align: top;
  }
  .article-body :global(tr:last-child td) {
    border-bottom: none;
  }
  .article-body :global(tr:hover td) {
    background: var(--white);
  }
  .article-body :global(table) {
    border: 1px solid var(--border);
  }

  .tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    letter-spacing: 0.03em;
  }
  .tag-pm {
    background: var(--blue-light);
    color: #1e4a8a;
  }
  .tag-fintech {
    background: var(--peach);
    color: var(--peach-dark);
  }
  .tag-ia {
    background: var(--mint);
    color: var(--mint-dark);
  }

  .progress-bar {
    position: fixed;
    top: 56px;
    left: 0;
    height: 2px;
    background: var(--blue-dark);
    z-index: 99;
    width: 0%;
    transition: width 0.1s linear;
  }
  .breadcrumb-bar {
    padding: 0.85rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--white);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--gray);
  }
  .breadcrumb a {
    color: var(--blue-dark);
  }
  .breadcrumb-sep {
    color: var(--border);
  }

  .article-hero {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    position: relative;
  }
  .article-hero-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: flex-end;
    padding: 1rem 1.25rem;
    position: relative;
    overflow: hidden;
  }
  .hero-ia {
    background: linear-gradient(135deg, #1a1a2e 60%, #2d3561);
  }
  .hero-fintech {
    background: linear-gradient(135deg, #fff5ee 60%, #ffe4d0);
  }
  .hero-pm {
    background: linear-gradient(135deg, #e8f4fc 60%, #d4e8f5);
  }
  .hero-deco {
    position: absolute;
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: radial-gradient(circle, var(--blue-mid) 0%, transparent 50%);
    opacity: 0.15;
  }
  .hero-label {
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 500;
    position: relative;
  }
  .hero-fintech .hero-label,
  .hero-pm .hero-label {
    color: rgba(0, 0, 0, 0.2);
  }

  .article-outer {
    padding: 2rem 0 4rem;
  }
  .article-col {
    width: 100%;
    max-width: 680px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }
  .article-header {
    margin-bottom: 2rem;
  }
  .article-header-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .article-title {
    font-family: "Fraunces", serif;
    font-size: clamp(1.75rem, 5vw, 2.6rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }
  .article-subtitle {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--gray);
    margin-bottom: 1.5rem;
    font-style: italic;
  }

  .author-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    gap: 1rem;
    flex-wrap: wrap;
  }
  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .author-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }
  .author-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .author-name {
    font-size: 0.85rem;
    font-weight: 500;
  }
  .author-meta {
    font-size: 0.72rem;
    color: var(--gray);
  }
  .article-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .read-time {
    font-size: 0.75rem;
    color: var(--gray);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    cursor: pointer;
    border: none;
    font-family: "DM Sans", sans-serif;
    transition: all 0.2s;
  }
  .share-wa {
    background: #25d366;
    color: white;
  }
  .share-wa:hover {
    background: #20ba5a;
  }
  .share-li {
    background: var(--blue-dark);
    color: white;
  }
  .share-li:hover {
    background: var(--blue-mid);
  }

  .article-body {
    font-size: 1rem;
    line-height: 1.85;
    color: #2d2d3a;
    margin-top: 2rem;
  }
  .article-body :global(p) {
    margin-bottom: 1.5rem;
  }
  .article-body :global(h2) {
    font-family: "Fraunces", serif;
    font-size: 1.5rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1rem;
    color: var(--black);
  }
  .article-body :global(h3) {
    font-family: "Fraunces", serif;
    font-size: 1.15rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--black);
  }
  .article-body :global(strong) {
    font-weight: 500;
    color: var(--black);
  }
  .article-body :global(em) {
    font-style: italic;
    color: var(--gray);
  }
  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 1rem 0 1.5rem 1.5rem;
  }
  .article-body :global(li) {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .article-body :global(blockquote) {
    border-left: 3px solid var(--blue-dark);
    padding: 0.75rem 1.25rem;
    margin: 2rem 0;
    background: var(--white);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--gray);
    line-height: 1.7;
  }
  .article-body :global(a) {
    color: var(--blue-dark);
    border-bottom: 1px solid var(--blue-light);
  }

  .article-tags {
    margin-top: 2rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .article-tags-label {
    font-size: 0.72rem;
    color: var(--gray);
    margin-right: 0.25rem;
  }

  .bottom-share {
    padding: 1.5rem 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    margin-top: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .bottom-share-label {
    font-size: 0.78rem;
    color: var(--gray);
  }
  .bottom-share-btns {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .newsletter-cta {
    background: var(--black);
    color: var(--white);
    padding: 2rem;
    margin: 3rem 0;
    text-align: center;
  }
  .newsletter-cta h3 {
    font-family: "Fraunces", serif;
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .newsletter-cta p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }
  .newsletter-cta-form {
    display: flex;
    max-width: 400px;
    margin: 0 auto;
  }
  .newsletter-cta-form input {
    flex: 1;
    padding: 0.75rem 1rem;
    border: none;
    font-family: "DM Sans", sans-serif;
    font-size: 0.85rem;
    outline: none;
    min-width: 0;
  }
  .newsletter-cta-form button {
    padding: 0.75rem 1.25rem;
    background: var(--blue-dark);
    color: var(--white);
    border: none;
    font-family: "DM Sans", sans-serif;
    font-size: 0.82rem;
    cursor: pointer;
    white-space: nowrap;
  }

  .author-bio {
    background: var(--white);
    border: 1px solid var(--border);
    padding: 1.5rem;
    margin: 2rem 0;
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .author-bio-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 2px solid var(--border);
  }
  .author-bio-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .author-bio-name {
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 0.25rem;
  }
  .author-bio-text {
    font-size: 0.82rem;
    line-height: 1.7;
    color: var(--gray);
  }
  .author-bio-link {
    font-size: 0.78rem;
    color: var(--blue-dark);
    border-bottom: 1px solid var(--blue-light);
    padding-bottom: 1px;
    margin-top: 0.5rem;
    display: inline-block;
  }

  .related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }
  .related-label {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gray);
    margin-bottom: 1.25rem;
  }
  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .related-card {
    background: var(--white);
    border: 1px solid var(--border);
    display: flex;
    overflow: hidden;
    transition:
      border-color 0.2s,
      transform 0.2s;
  }
  .related-card:hover {
    border-color: var(--blue-mid);
    transform: translateY(-2px);
  }
  .related-card-img {
    width: 90px;
    flex-shrink: 0;
    aspect-ratio: 1/1;
    overflow: hidden;
  }
  .related-img-placeholder {
    width: 100%;
    height: 100%;
  }
  .related-img-ia {
    background: linear-gradient(135deg, #1a1a2e, #2d3561);
  }
  .related-img-fintech {
    background: linear-gradient(135deg, #fff5ee, #ffe4d0);
  }
  .related-img-pm {
