---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const todos = await getCollection("articulos");
const ordenados = todos.sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf(),
);
const destacado = ordenados.find((a) => a.data.destacado) || ordenados[0];
const resto = ordenados.filter((a) => a.slug !== destacado.slug);

const pilarLabel = {
  pm: "Product Management",
  fintech: "Fintech Latam",
  ia: "IA aplicada a producto",
};
const pilarCount = {
  pm: todos.filter((a) => a.data.pilar === "pm").length,
  fintech: todos.filter((a) => a.data.pilar === "fintech").length,
  ia: todos.filter((a) => a.data.pilar === "ia").length,
};

function fechaCorta(fecha) {
  return new Date(fecha).toLocaleDateString("es-PE", {
    month: "long",
    year: "numeric",
  });
}
---

<Base
  titulo="Artículos — FerTechPro"
  descripcion="Product Management, Fintech Latam e IA aplicada a producto."
>
  <Nav paginaActual="articulos" />

  <div class="page-header">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Inicio</a><span>›</span><span>Artículos</span>
      </div>
      <h1 class="page-title">Todos los artículos</h1>
      <p class="page-desc">
        Product Management, Fintech Latam e IA aplicada a producto. Un artículo
        por semana, cada lunes.
      </p>
    </div>
  </div>

  <div class="filters">
    <div class="container">
      <div class="filters-inner">
        <span class="filter-label">Filtrar:</span>
        <button class="filter-btn active-all" onclick="setFilter('all',this)"
          >Todos <span class="filter-count">{todos.length}</span></button
        >
        <button class="filter-btn" onclick="setFilter('pm',this)"
          >Product Management <span class="filter-count">{pilarCount.pm}</span
          ></button
        >
        <button class="filter-btn" onclick="setFilter('fintech',this)"
          >Fintech Latam <span class="filter-count">{pilarCount.fintech}</span
          ></button
        >
        <button class="filter-btn" onclick="setFilter('ia',this)"
          >IA aplicada a producto <span class="filter-count"
            >{pilarCount.ia}</span
          ></button
        >
      </div>
    </div>
  </div>

  <div class="container">
    <div class="sort-bar">
      <span class="sort-count" id="sort-count">{todos.length} artículos</span>
    </div>

    <div class="content-layout">
      <div>
        <div class="articles-grid" id="articles-grid">
          <!-- DESTACADO -->
          <a
            href={`/articulos/${destacado.slug}`}
            class="card-featured"
            data-pilar={destacado.data.pilar}
          >
            <div class="card-featured-img">
              {
                destacado.data.imagen ? (
                  <img
                    src={destacado.data.imagen}
                    alt={destacado.data.titulo}
                    style="width:100%;height:100%;object-fit:cover;display:block;"
                  />
                ) : (
                  <div
                    class={`img-placeholder img-placeholder-${destacado.data.pilar}`}
                  >
                    <div class="img-deco" />
                    <span class="img-label">Tu caricatura aquí</span>
                  </div>
                )
              }
            </div>
            <div class="card-featured-body">
              <span class="featured-badge">★ Artículo destacado</span>
              <span class={`tag tag-${destacado.data.pilar}`}
                >{pilarLabel[destacado.data.pilar]}</span
              >
              <div class="title-featured">{destacado.data.titulo}</div>
              <div class="excerpt">{destacado.data.extracto}</div>
              <div class="meta">
                <span>Fernando Mendoza</span><span>·</span>
                <span>{destacado.data.lectura} min lectura</span><span>·</span>
                <span>{fechaCorta(destacado.data.fecha)}</span>
              </div>
            </div>
          </a>

          <!-- RESTO DE ARTÍCULOS -->
          {
            resto.map((a) => (
              <a
                href={`/articulos/${a.slug}`}
                class="card-regular"
                data-pilar={a.data.pilar}
              >
                <div class="card-regular-img">
                  {a.data.imagen ? (
                    <img
                      src={a.data.imagen}
                      alt={a.data.titulo}
                      style="width:100%;height:100%;object-fit:cover;display:block;"
                    />
                  ) : (
                    <div
                      class={`img-placeholder img-placeholder-${a.data.pilar}`}
                    >
                      <div class="img-deco" />
                    </div>
                  )}
                </div>
                <div class="card-regular-body">
                  <span class={`tag tag-${a.data.pilar}`}>
                    {pilarLabel[a.data.pilar]}
                  </span>
                  <div class="title-regular">{a.data.titulo}</div>
                  <div class="meta">
                    <>
                      <span>{a.data.lectura} min</span>
                      <span>·</span>
                    </>
                    <span>{fechaCorta(a.data.fecha)}</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <!-- SIDEBAR -->
      <div class="sidebar">
        <div class="sidebar-card sidebar-nl">
          <div class="sidebar-card-title">Newsletter semanal</div>
          <p
            style="font-size:.82rem;color:var(--gray);margin-bottom:1rem;line-height:1.6"
          >
            Un artículo cada lunes. Sin spam.
          </p>
          <input type="email" placeholder="tu@email.com" />
          <button>Suscribirme →</button>
        </div>
        <div class="sidebar-card">
          <div class="sidebar-card-title">Más leídos</div>
          {
            ordenados.slice(0, 3).map((a, i) => (
              <a href={`/articulos/${a.slug}`} class="sidebar-post">
                <span class="sidebar-post-num">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div>
                  <div class="sidebar-post-title">{a.data.titulo}</div>
                  <div class="sidebar-post-tag">
                    <span
                      class={`tag tag-${a.data.pilar}`}
                      style="font-size:.6rem;"
                    >
                      {pilarLabel[a.data.pilar]}
                    </span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
        <div class="sidebar-card">
          <div class="sidebar-card-title">Explorar por pilar</div>
          <div
            style="display:flex;flex-direction:column;gap:.5rem;margin-top:.25rem;"
          >
            <a
              href="#"
              onclick="setFilter('pm',document.querySelector('.filter-btn:nth-child(3)'));return false;"
              style="display:flex;justify-content:space-between;align-items:center;padding:.6rem 0;border-bottom:1px solid var(--border);"
            >
              <span class="tag tag-pm">Product Management</span><span
                style="font-size:.72rem;color:var(--gray);"
                >{pilarCount.pm} artículos</span
              >
            </a>
            <a
              href="#"
              onclick="setFilter('fintech',document.querySelector('.filter-btn:nth-child(4)'));return false;"
              style="display:flex;justify-content:space-between;align-items:center;padding:.6rem 0;border-bottom:1px solid var(--border);"
            >
              <span class="tag tag-fintech">Fintech Latam</span><span
                style="font-size:.72rem;color:var(--gray);"
                >{pilarCount.fintech} artículos</span
              >
            </a>
            <a
              href="#"
              onclick="setFilter('ia',document.querySelector('.filter-btn:nth-child(5)'));return false;"
              style="display:flex;justify-content:space-between;align-items:center;padding:.6rem 0;"
            >
              <span class="tag tag-ia">IA aplicada a producto</span><span
                style="font-size:.72rem;color:var(--gray);"
                >{pilarCount.ia} artículos</span
              >
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 500;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    letter-spacing: 0.03em;
  }
  .tag-pm {
    background: var(--blue-light);
    color: #1e4a8a;
  }
  .tag-fintech {
    background: var(--peach);
    color: var(--peach-dark);
  }
  .tag-ia {
    background: var(--mint);
    color: var(--mint-dark);
  }

  .page-header {
    padding: 2.5rem 0 1.5rem;
    border-bottom: 1px solid var(--border);
    background: var(--white);
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    color: var(--gray);
    margin-bottom: 1rem;
  }
  .breadcrumb a {
    color: var(--blue-dark);
  }
  .page-title {
    font-family: "Fraunces", serif;
    font-size: clamp(1.8rem, 6vw, 2.8rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }
  .page-desc {
    font-size: 0.88rem;
    line-height: 1.75;
    color: var(--gray);
  }

  .filters {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
    background: var(--white);
    position: sticky;
    top: 56px;
    z-index: 90;
  }
  .filters-inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filters-inner::-webkit-scrollbar {
    display: none;
  }
  .filter-label {
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gray);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.35rem 0.8rem;
    border-radius: 20px;
    cursor: pointer;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--gray);
    white-space: nowrap;
    flex-shrink: 0;
    font-family: "DM Sans", sans-serif;
    transition: all 0.15s;
  }
  .filter-btn:hover {
    border-color: var(--blue-mid);
    color: var(--black);
  }
  .filter-btn.active-all {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }
  .filter-btn.active-pm {
    background: var(--blue-light);
    color: #1e4a8a;
    border-color: var(--blue-light);
  }
  .filter-btn.active-fintech {
    background: var(--peach);
    color: var(--peach-dark);
    border-color: var(--peach);
  }
  .filter-btn.active-ia {
    background: var(--mint);
    color: var(--mint-dark);
    border-color: var(--mint);
  }
  .filter-count {
    font-size: 0.62rem;
    background: rgba(0, 0, 0, 0.08);
    padding: 0.1rem 0.35rem;
    border-radius: 20px;
  }
  .active-all .filter-count {
    background: rgba(255, 255, 255, 0.2);
  }

  .sort-bar {
    padding: 0.85rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }
  .sort-count {
    font-size: 0.78rem;
    color: var(--gray);
  }

  .articles-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1.5rem 0 4rem;
  }

  .card-featured {
    background: var(--white);
    border: 1px solid var(--border);
    overflow: hidden;
    transition:
      border-color 0.2s,
      transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .card-featured:hover {
    border-color: var(--blue-mid);
    transform: translateY(-2px);
  }
  .card-featured-img {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    position: relative;
  }
  .card-featured-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .card-regular {
    background: var(--white);
    border: 1px solid var(--border);
    overflow: hidden;
    transition:
      border-color 0.2s,
      transform 0.2s;
    display: flex;
    flex-direction: row;
  }
  .card-regular:hover {
    border-color: var(--blue-mid);
    transform: translateY(-2px);
  }
  .card-regular-img {
    width: 110px;
    flex-shrink: 0;
    aspect-ratio: 1/1;
    overflow: hidden;
    position: relative;
  }
  .card-regular-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .img-placeholder-ia {
    background: linear-gradient(135deg, #1a1a2e 60%, #2d3561);
  }
  .img-placeholder-fintech {
    background: linear-gradient(135deg, #fff5ee 60%, #ffe4d0);
  }
  .img-placeholder-pm {
    background: linear-gradient(135deg, #e8f4fc 60%, #d4e8f5);
  }
  .img-deco {
    position: absolute;
    border-radius: 50%;
    opacity: 0.06;
  }
  .img-placeholder-ia .img-deco {
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: radial-gradient(circle, var(--blue-mid) 0%, transparent 50%);
  }
  .img-placeholder-fintech .img-deco {
    width: 200%;
    height: 200%;
    top: -50%;
    right: -50%;
    background: radial-gradient(circle, var(--peach-dark) 0%, transparent 50%);
    opacity: 0.15;
  }
  .img-placeholder-pm .img-deco {
    width: 200%;
    height: 200%;
    top: -50%;
    left: -50%;
    background: radial-gradient(circle, var(--blue-dark) 0%, transparent 50%);
    opacity: 0.12;
  }
  .img-label {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.4;
    font-weight: 500;
    color: var(--white);
  }

  .title-featured {
    font-family: "Fraunces", serif;
    font-size: 1.3rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .title-regular {
    font-family: "Fraunces", serif;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: -0.01em;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .excerpt {
    font-size: 0.83rem;
    line-height: 1.7;
    color: var(--gray);
  }
  .meta {
    font-size: 0.7rem;
    color: var(--gray);
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    padding-top: 0.5rem;
    border-top: 1px solid var(--border);
  }
  .featured-badge {
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--blue-dark);
    font-weight: 500;
  }

  .content-layout {
    display: block;
  }
  .sidebar {
    display: none;
  }

  @media (min-width: 640px) {
    .articles-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      padding: 1.5rem 0 4rem;
    }
    .card-featured {
      grid-column: span 2;
    }
    .card-regular {
      flex-direction: column;
    }
    .card-regular-img {
      width: 100%;
      aspect-ratio: 16/9;
    }
    .card-regular-body {
      padding: 1.25rem;
    }
    .title-regular {
      font-size: 1rem;
      -webkit-line-clamp: 2;
    }
  }
  @media (min-width: 1024px) {
    .filters {
      top: 64px;
    }
    .content-layout {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 3rem;
      align-items: start;
    }
    .articles-grid {
      grid-template-columns: repeat(3, 1fr);
      padding: 1.5rem 0 4rem;
    }
    .card-featured {
      grid-column: span 3;
      flex-direction: row;
    }
    .card-featured-img {
      width: 55%;
      aspect-ratio: auto;
      flex-shrink: 0;
    }
    .card-featured-body {
      padding: 2rem;
      justify-content: center;
    }
    .title-featured {
      font-size: 1.6rem;
    }
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      position: sticky;
      top: 130px;
    }
    .sidebar-card {
      background: var(--white);
      border: 1px solid var(--border);
      padding: 1.5rem;
    }
    .sidebar-card-title {
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gray);
      margin-bottom: 1rem;
    }
    .sidebar-nl input {
      width: 100%;
      padding: 0.7rem 1rem;
      border: 1px solid var(--border);
      font-family: "DM Sans", sans-serif;
      font-size: 0.82rem;
      background: var(--bg);
      outline: none;
      margin-bottom: 0.5rem;
      display: block;
    }
    .sidebar-nl button {
      width: 100%;
      padding: 0.7rem;
      background: var(--blue-dark);
      color: var(--white);
      border: none;
      font-family: "DM Sans", sans-serif;
      font-size: 0.8rem;
      cursor: pointer;
    }
    .sidebar-post {
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--border);
      display: flex;
      gap: 0.75rem;
      text-decoration: none;
      color: inherit;
    }
    .sidebar-post:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }
    .sidebar-post-num {
      font-family: "Fraunces", serif;
      font-size: 1.1rem;
      color: var(--border);
      font-weight: 600;
      flex-shrink: 0;
      line-height: 1.3;
    }
    .sidebar-post-title {
      font-size: 0.82rem;
      line-height: 1.45;
    }
    .sidebar-post-tag {
      margin-top: 0.3rem;
    }
  }
</style>

<script>
  function setFilter(p, btn) {
    document
      .querySelectorAll(".filter-btn")
      .forEach((b) => (b.className = "filter-btn"));
    btn.classList.add("active-" + p);
    let v = 0;
    document.querySelectorAll("[data-pilar]").forEach((r) => {
      if (p === "all" || r.dataset.pilar === p) {
        r.style.display = "";
        v++;
      } else r.style.display = "none";
    });
    document.getElementById("sort-count").textContent = v + " artículos";
  }
</script>
